# ============================================================
# REQUIRED — the app won't start without these.
# ============================================================

# WhatsApp token encryption (64 hex chars = 32 bytes, AES-256-GCM).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this value orphans every token encrypted under the previous
# key — users have to re-save their WhatsApp settings to reconnect.
ENCRYPTION_KEY=your-64-char-hex-key-here

# Meta App Secret (Meta for Developers → App Settings → Basic).
# Verifies the HMAC-SHA256 signature on every inbound webhook POST.
# Required — without it the webhook rejects every request.
META_APP_SECRET=your-meta-app-secret

# Convex (self-hosted or Convex Cloud). This is the client-facing
# deployment URL used by `ConvexReactClient` in `src/app/
# ConvexClientProvider.tsx`, which is mounted app-wide, so the app fails
# to load without it. Self-hosted: printed by `npx convex dev` (and
# written to this file automatically); Convex Cloud: the
# https://<name>.convex.cloud URL from your dashboard.
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Convex HTTP Actions ("site") origin for the same deployment — used for
# routes Convex exposes over plain HTTP (e.g. Convex Auth's sign-in/
# sign-out endpoints, file serving, and — as of Phase 8, Task 4b — the
# WhatsApp webhook httpActions in `convex/http.ts`). REQUIRED as of Task
# 4b: `src/app/api/whatsapp/webhook/route.ts` forwards every inbound
# Meta webhook to `${NEXT_PUBLIC_CONVEX_SITE_URL}/whatsapp/ingest` (and
# GET verification to `.../whatsapp/webhook`) — without it, that route
# fails closed (logs an error, still acks Meta with a fast 200/500, but
# nothing reaches Convex). Self-hosted: usually the same host on a
# different port; Convex Cloud: the https://<name>.convex.site URL
# `npx convex dev` prints/saves alongside NEXT_PUBLIC_CONVEX_URL.
#
# NOTE the `NEXT_PUBLIC_` prefix — this is READ SERVER-SIDE ONLY (inside
# the webhook route handler, never in a client component), but is
# prefixed for consistency with `NEXT_PUBLIC_CONVEX_URL` above; nothing
# about its value is sensitive (it's a URL, not a credential).
NEXT_PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211

# Shared secret gating Convex's `POST /whatsapp/ingest` / `GET
# /whatsapp/webhook` httpActions (`convex/http.ts`) — those are otherwise
# public, unauthenticated Convex HTTP routes, reachable by anyone who
# knows the deployment's site URL. Required as of Phase 8, Task 4b:
# `src/app/api/whatsapp/webhook/route.ts` sends this as the
# `x-wacrm-proxy-secret` header on every forwarded request. MUST be set
# to the SAME value on both this app (here) and the Convex deployment
# (`npx convex env set WEBHOOK_PROXY_SECRET <value>`) — a mismatch (or
# leaving either side unset) makes every inbound WhatsApp message/status/
# template webhook fail with a logged 401, silently dropped from Meta's
# point of view (it still gets acked 200).
#
# Left commented (unlike META_APP_SECRET/ENCRYPTION_KEY above, which
# have obviously-inert placeholders): unlike those, Meta never validates
# this value against anything, so a shared, un-generated default copied
# verbatim from this template across many installs would be a genuine,
# silently-exploitable weakness rather than just an inert placeholder.
# Generate a real value per deployment:
#   openssl rand -hex 32
# WEBHOOK_PROXY_SECRET=generate-a-long-random-string

# ============================================================
# RECOMMENDED — safe defaults exist but you'll want to set these.
# ============================================================

# Canonical public URL of this deployment (scheme + host, no trailing
# slash), e.g. https://crm.example.com.
#
# STATUS: currently UNUSED by the app. The Convex migration removed the
# `/api/account/invitations` route this used to feed; invite links are
# now built in the browser from `window.location.origin` (see
# `src/components/settings/invite-member-dialog.tsx`), which is always
# correct without any env var. No sitemap/OG-image code reads it today
# either. Left commented as a reserved name for a future request-less
# link generator (cron/background worker) or static metadata — setting
# it now has no effect. NOTE: the Convex-Auth redirect/link base is a
# SEPARATE variable named `SITE_URL`, set on the Convex deployment via
# `npx convex env set SITE_URL <url>`, not here.
# NEXT_PUBLIC_SITE_URL=https://crm.example.com

# Default language locale (e.g. en)
NEXT_PUBLIC_APP_LOCALE=en

# ============================================================
# OPTIONAL — only needed if you use the feature.
# ============================================================

# ALLOWED_INVITE_HOSTS — currently UNUSED. It used to allow-list the
# hostnames the old `/api/account/invitations` route would publish in
# invite URLs (a guard against `Host`-header spoofing on bare, unproxied
# deployments). The Convex migration removed that route: invite links
# are generated client-side from `window.location.origin`, so there is
# no server-derived host to guard and nothing reads this variable. Kept
# as a breadcrumb; safe to omit.
#
# Example (historical):
#   ALLOWED_INVITE_HOSTS=crm.example.com,crm-staging.example.com

# Meta App ID (Meta for Developers → App Settings → Basic). Required to
# create/edit message templates with an IMAGE header: Meta only accepts a
# Resumable-Upload media handle (not a plain URL) as the header sample, and
# that upload is app-scoped. Without it, image-header template submission
# returns a clear error; text/body-only templates are unaffected. Pair
# with META_APP_SECRET.
# META_APP_ID=your-meta-app-id

# When "true", POST /api/whatsapp/templates/submit skips the Meta call
# and stores the row with a synthetic `dry-run-<uuid>` meta_template_id.
# Set this in CI and local development so you can exercise the full
# template UI without a real WABA. Leave unset (or "false") in prod.
# WHATSAPP_TEMPLATES_DRY_RUN=true

# ------------------------------------------------------------------
# AI reply assistant (optional)
# ------------------------------------------------------------------
# The AI assistant is bring-your-own-key: each account pastes its own
# OpenAI or Anthropic key under Settings → AI Assistant. The key is
# stored AES-256-GCM-encrypted with ENCRYPTION_KEY (above) — there is
# NO global provider key env var, and nothing here is required for the
# feature to work. The two vars below only tune behaviour.
#
# The AI knowledge base uses Convex's native full-text + vector search
# (see `convex/aiKnowledge.ts` / the search+vector indexes in
# `convex/schema.ts`) — no Postgres/pgvector setup needed. Semantic
# search just needs a per-account embeddings key set in Settings → AI
# Assistant. Still no env var required.

# Per-call timeout for provider requests, in milliseconds. Default 30000.
# AI_REQUEST_TIMEOUT_MS=30000

# How many recent text messages of a conversation to send the model as
# context (draft + auto-reply). Default 20.
# AI_CONTEXT_MESSAGE_LIMIT=20

# Reply pacing ("human-paced AI replies") — how long the bot waits after
# an inbound before generating a reply, and how long the generated text
# then "types" before it lands. See `convex/lib/ai/pacing.ts` for the
# exact arithmetic; all seven vars below only tune it, none are required.
#
# IMPORTANT — AI_REPLY_DEBOUNCE_MS CHANGED MEANING. It used to be the
# single flat delay before every reply (default 12000ms, applied to
# everything). It is now only the NEUTRAL middle tier of a three-tier
# debounce (default 3000ms) — a short/complete-looking message uses
# AI_REPLY_DEBOUNCE_FAST_MS instead, and a short/unpunctuated fragment
# uses AI_REPLY_DEBOUNCE_SLOW_MS. A stale 12000 carried over from before
# this changed will make every NEUTRAL-shaped reply wait 12s before it
# even starts generating — surprising, not broken. `=0` remains the
# documented kill switch and still silences all three tiers at once
# (immediate dispatch, no debounce at all), exactly as before.

# Debounce (listen-before-replying) window, in milliseconds, for a
# NEUTRAL-shaped message (see above). Default 3000. Set to 0 to disable
# debouncing entirely — silences all three tiers below too.
# AI_REPLY_DEBOUNCE_MS=3000

# Debounce tier for a message that reads as a COMPLETE thought (ends in
# terminal punctuation, or long). Default 2000.
# AI_REPLY_DEBOUNCE_FAST_MS=2000

# Debounce tier for a short, unpunctuated FRAGMENT ("hi", "how much") —
# almost certainly the first half of a burst still being typed. Default
# 6000.
# AI_REPLY_DEBOUNCE_SLOW_MS=6000

# Simulated typing speed, in characters/second, used to size the
# artificial delivery delay after generation finishes. Default 18.
# AI_TYPING_CHARS_PER_SEC=18

# Randomness applied to the typing delay so replies don't land at a
# suspiciously exact cadence every time, as a fraction (0.25 = +/-25%).
# Default 0.25.
# AI_TYPING_JITTER=0.25

# Floor on the artificial typing delay, in milliseconds — even a
# one-word reply waits at least this long. Default 3000.
# AI_TYPING_MIN_MS=3000

# Ceiling on the artificial typing delay, in milliseconds. Hard-capped at
# 20000 in code regardless of this value (Meta's typing indicator
# auto-dismisses at 25s with no documented refresh). Default 15000.
# AI_TYPING_MAX_MS=15000

# ============================================================
# Web Push (PWA notifications) — optional; push is inert until set.
# ============================================================
# Generate one keypair with:  npx web-push generate-vapid-keys --json
# The PUBLIC key is safe to expose; the PRIVATE key is a secret and must
# live ONLY in the Convex deployment env (never in a NEXT_PUBLIC_ var).

# Client (Netlify build): the VAPID public key the browser subscribes with.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Convex deployment env (set via `npx convex env set …`), NOT Netlify:
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@holidayys.co

# ============================================================
# Cloudflare R2 media storage — optional in the sense that the app
# still boots without these, but effectively REQUIRED once any media
# path is exercised. Outbound browser uploads (composer attachments,
# agent voice notes, template header images, flow `send_media`,
# avatars) THROW immediately without them (`convex/lib/r2/config.ts`'s
# `r2ConfigFromEnv`). Inbound WhatsApp media degrades SILENTLY instead
# — no `mediaKey` gets attached, the bubble renders "unavailable", and
# nothing logs where a human is watching
# (`whatsappConfig.resolveInboundMedia` best-effort-wraps the R2
# call). Full config, the required bucket CORS policy, and the
# pre-deploy verification gate:
#   docs/superpowers/specs/2026-07-19-cloudflare-r2-media-storage-design.md
#   docs/superpowers/plans/2026-07-19-r2-media-write-path.md (Task 8)
# ============================================================

# Client (Netlify build): the public custom domain R2 objects are
# served from — resolves a stored object key straight into a display
# URL, entirely client-side (`src/lib/storage/media-url.ts`). Without
# it, `resolveMediaUrl` degrades gracefully (falls back to any legacy
# URL on the row, logging a `console.error`) rather than throwing —
# but any media uploaded AFTER the R2 cutover has no legacy URL to
# fall back to, so it will not load until this is set.
# NEXT_PUBLIC_R2_PUBLIC_HOST=https://objs.example.com

# Convex deployment env (set via `npx convex env set …`), NOT Netlify.
# aws4fetch signs with the access key pair alone — there is no
# separate R2 API token to set.
# R2_BUCKET=your-bucket-name
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_PUBLIC_HOST=https://objs.example.com
